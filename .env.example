# Canonical site URL for Open Graph and metadata (no trailing slash). On Vercel,
# VERCEL_URL is used automatically if this is unset.
# NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# --- Contact form (Nodemailer) — server only, never NEXT_PUBLIC_ ---
# Copy to `.env.local` and fill real values. Restart `npm run dev` after changes.

# SMTP server (Gmail example below; use your provider’s host/port)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"

# Login for SMTP (Gmail: full address; password = App Password, not normal password)
SMTP_USER="your.email@gmail.com"
SMTP_PASS="your-16-char-app-password"

# Where you receive contact form messages
CONTACT_TO_EMAIL="ratulroy8863@gmail.com"

# "From" address (often same as SMTP_USER; must be allowed by your provider)
CONTACT_FROM_EMAIL="your.email@gmail.com"
